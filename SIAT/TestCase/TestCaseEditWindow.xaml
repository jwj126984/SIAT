<Window x:Class="SIAT.TestCaseEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="用例编辑" Height="800" Width="1430"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004175"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E1E4E8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#C9CDD0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C9CDD0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B6BBBF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- 列表项样式 -->
        <Style x:Key="ListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                    <Setter Property="Foreground" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="83*"/>
            <ColumnDefinition Width="117*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E1E4E8" BorderThickness="0,0,0,1" Padding="15,10" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="用例编辑" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Text="用例名称: " VerticalAlignment="Center"/>
                <TextBlock x:Name="TestCaseNameText" Text="{Binding TestCaseConfig.Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button x:Name="SaveButton" Content="保存" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
                <Button x:Name="SaveAsButton" Content="另存为" Style="{StaticResource SecondaryButtonStyle}" Click="SaveAsButton_Click"/>
                <Button x:Name="CloseButton" Content="关闭" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="15,15,15,15" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：项目列表 -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 项目列表标题 -->
                <TextBlock Grid.Row="0" Text="可用项目" Style="{StaticResource SectionTitleStyle}"/>

                <!-- 项目列表 -->
                <Grid Grid.Row="1" Margin="0,25,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索框和添加按钮 -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="ProjectSearchTextBox" Height="30" TextChanged="ProjectSearchTextBox_TextChanged" ToolTip="搜索项目..." FontSize="13" Padding="5,2" Background="White" BorderThickness="1" BorderBrush="#CCCCCC"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="搜索项目..." Foreground="#999999" FontSize="13" Margin="8,6,0,0" IsHitTestVisible="False" Visibility="Collapsed"/>
                       </Grid>
                    <ListView Grid.Row="1" x:Name="ProjectList" ItemsSource="{Binding FilteredProjects}" SelectedItem="{Binding SelectedProject}" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="ProjectList_SelectionChanged" MouseDoubleClick="ProjectList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="项目名称" Width="270">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <!-- 中间：用例编辑列表 -->
            <Grid Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 用例编辑列表标题 -->
                <TextBlock Grid.Row="0" Text="用例编辑列表" Style="{StaticResource SectionTitleStyle}"/>

                <!-- 用例项目列表 -->
                <ListView Grid.Row="1" x:Name="TestCaseProjectList" ItemsSource="{Binding TestCaseProjects}" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="TestCaseProjectList_SelectionChanged" MouseDoubleClick="TestCaseProjectList_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="序号" Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Index}" Padding="5,2" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="项目名称" Width="250">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="描述" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Description}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="添加时间" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AddedDate, StringFormat='yyyy-MM-dd HH:mm'}" Padding="5,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 项目操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="MoveUpButton" Content="上移" Style="{StaticResource PrimaryButtonStyle}" Click="MoveUpButton_Click"/>
                    <Button x:Name="MoveDownButton" Content="下移" Style="{StaticResource PrimaryButtonStyle}" Click="MoveDownButton_Click"/>
                    <Button x:Name="RemoveButton" Content="移除" Style="{StaticResource SecondaryButtonStyle}" Click="RemoveButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- 右侧：合格值判断设置 -->
            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 合格值判断标题 -->
                <TextBlock Grid.Row="0" Text="合格值判断设置" Style="{StaticResource SectionTitleStyle}"/>

                <!-- 变量列表 -->
                <ListView Grid.Row="1" x:Name="VariableList" ItemsSource="{Binding SelectedTestCaseProjectVariables}" SelectedItem="{Binding SelectedVariable}" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="VariableList_SelectionChanged" Height="200" Margin="0,10,0,0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="变量名称" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VariableName}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding VariableName}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="变量类型" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VariableType}" Padding="5,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="合格值" Width="Auto">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding QualifiedValue}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding QualifiedValue}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 合格值判断设置内容 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="变量名称:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SelectedVariable.VariableName}" Margin="0,5,0,10" FontWeight="SemiBold"/>
                        
                        <TextBlock Text="变量类型:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding SelectedVariable.VariableType}" Margin="0,5,0,10"/>
                        
                        <TextBlock Text="合格值类型:" VerticalAlignment="Center" Margin="0,20,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <RadioButton Content="单个值" IsChecked="{Binding IsSingleValue, Mode=TwoWay}" Margin="0,0,20,0" Checked="SingleValue_Checked"/>
                            <RadioButton Content="范围" IsChecked="{Binding IsRange, Mode=TwoWay}" Checked="Range_Checked"/>
                        </StackPanel>
                        
                        <!-- 单个合格值 -->
                        <TextBlock Text="合格值:" VerticalAlignment="Center" Margin="0,10,0,0" Visibility="{Binding IsSingleValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <StackPanel Margin="0,10,0,0" Orientation="Vertical" IsEnabled="{Binding IsSingleValue}" Visibility="{Binding IsSingleValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox x:Name="SingleValueTextBox" Text="{Binding SingleValue, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" />
                            <TextBox x:Name="SingleValueNumericTextBox" Text="{Binding SingleValue, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" 
                                     PreviewTextInput="Numeric_PreviewTextInput" InputMethod.IsInputMethodEnabled="False" Visibility="Collapsed"/>
                            <ComboBox x:Name="SingleValueBoolComboBox" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" Visibility="Collapsed">
                                <ComboBoxItem Content="True"/>
                                <ComboBoxItem Content="False"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <!-- 合格范围 -->
                        <TextBlock Text="合格范围:" VerticalAlignment="Center" Margin="0,10,0,0" Visibility="{Binding IsRange, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" IsEnabled="{Binding IsRange}" Visibility="{Binding IsRange, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Width="100" Orientation="Vertical">
                                <TextBox x:Name="RangeStartTextBox" Text="{Binding RangeStart, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" />
                                <TextBox x:Name="RangeStartNumericTextBox" Text="{Binding RangeStart, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" 
                                         PreviewTextInput="Numeric_PreviewTextInput" InputMethod.IsInputMethodEnabled="False" Visibility="Collapsed"/>
                            </StackPanel>
                            <TextBlock Text="至" VerticalAlignment="Center" Margin="5,0,5,0"/>
                            <StackPanel Width="100" Orientation="Vertical">
                                <TextBox x:Name="RangeEndTextBox" Text="{Binding RangeEnd, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" />
                                <TextBox x:Name="RangeEndNumericTextBox" Text="{Binding RangeEnd, Mode=TwoWay}" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF" 
                                         PreviewTextInput="Numeric_PreviewTextInput" InputMethod.IsInputMethodEnabled="False" Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Button Content="保存合格值设置" Style="{StaticResource PrimaryButtonStyle}" Margin="0,20,0,0" Click="SaveQualifiedValueButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E1E4E8" BorderThickness="0,1,0,0" Padding="10,5" Grid.ColumnSpan="2">
            <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="#666666"/>
        </Border>
    </Grid>
</Window>