<Window x:Class="SIAT.SystemSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="" 
        Height="650" 
        Width="1050"
        MinHeight="550"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- 关闭按钮样式 -->
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="BorderBrush" Value="#C82333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C82333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BD2130"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="BorderBrush" Value="#218838"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 文本框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="BorderBrush" Value="#DC3545"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 组合框样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 复选框样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 数据网格样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- 标签样式 -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- 文本块样式 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 分组框样式 -->
        <Style TargetType="GroupBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
           
        </Style>
    </Window.Resources>

    <!-- 窗口阴影效果 -->
    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="#0078D4" BorderBrush="#005A9E" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="⚙️" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="用户管理" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>

                    <!-- 窗口标题 -->
                    <TextBlock Grid.Column="1" 
                               Text="系统设置" 
                               FontSize="14"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               MouseDown="Window_MouseDown"/>

                    <!-- 按钮区域 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,5,0">
                        <!-- 最小化按钮 -->
                        <Button x:Name="WindowMinimizeButton"
                                Content="−" 
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Click="WindowMinimizeButton_Click"/>
                        
                        <!-- 最大化按钮 -->
                        <Button x:Name="WindowMaximizeButton"
                                Content="□" 
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Click="WindowMaximizeButton_Click"/>
                        
                        <!-- 关闭按钮 -->
                        <Button x:Name="WindowCloseButton"
                                Content="✕" 
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Click="WindowCloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主要内容区域 -->
            <Grid Grid.Row="1" Background="#F5F5F5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：用户列表 -->
                    <GroupBox Grid.Column="0" Header="用户列表" Margin="10,10,5,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 操作按钮 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <Button x:Name="AddUserButton"
                                        Content="+ 新增用户" 
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Click="AddUserButton_Click"
                                        Width="100"/>
                                <Button x:Name="RefreshButton"
                                        Content="刷新" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="RefreshButton_Click"
                                        Width="80"
                                        Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- 用户列表数据网格 -->
                            <DataGrid Grid.Row="1" 
                                      x:Name="UsersDataGrid" 
                                      ItemsSource="{Binding Users}"
                                      SelectionChanged="UsersDataGrid_SelectionChanged"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="150"/>
                                    <DataGridTextColumn Header="用户角色" Binding="{Binding UserRole}" Width="120"/>
                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="70"/>
                                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreateTime, StringFormat=yyyy-MM-dd}" Width="130"/>
                                    <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginTime, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <!-- 分隔线 -->
                    <Rectangle Grid.Column="1" Width="1" Fill="#E0E0E0" Margin="0,10"/>

                    <!-- 右侧：用户详情编辑 -->
                    <GroupBox Grid.Column="2" Header="用户详情" Margin="5,10,10,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 用户名 -->
                                <Label Grid.Row="0" Content="用户名:"/>
                                <TextBox Grid.Row="1" 
                                         x:Name="UsernameTextBox"
                                         Text="{Binding SelectedUser.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,15"/>

                                <!-- 密码 -->
                                <Label Grid.Row="2" Content="密码:"/>
                                <TextBox Grid.Row="3" 
                                         x:Name="PasswordTextBox"
                                         Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,15"/>

                                <!-- 用户角色 -->
                                <Label Grid.Row="4" Content="用户角色:"/>
                                <ComboBox Grid.Row="5"
                                          x:Name="UserRoleComboBox"
                                          ItemsSource="{Binding UserRoles}"
                                          SelectedItem="{Binding SelectedUser.UserRole, Mode=TwoWay}"
                                          Margin="0,0,0,15"/>

                                <!-- 状态 -->
                                <Label Grid.Row="6" Content="状态:"/>
                                <CheckBox Grid.Row="7"
                                          x:Name="IsActiveCheckBox"
                                          Content="启用用户"
                                          IsChecked="{Binding SelectedUser.IsActive, Mode=TwoWay}"
                                          Margin="0,0,0,20"/>

                                <!-- 创建时间 -->
                                <Label Grid.Row="8" Content="创建时间:"/>
                                <TextBlock Grid.Row="9"
                                           x:Name="CreateTimeTextBlock"
                                           Text="{Binding SelectedUser.CreateTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                           Margin="0,0,0,15"/>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                    <Button x:Name="SaveButton"
                                            Content="保存" 
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Width="90"
                                            Click="SaveButton_Click"/>
                                    <Button x:Name="DeleteButton"
                                            Content="删除" 
                                            Style="{StaticResource DangerButtonStyle}"
                                            Margin="10,0,0,0"
                                            Width="90"
                                            Click="DeleteButton_Click"/>
                                </StackPanel>

                                <!-- 状态文本 -->
                                <TextBlock Grid.Row="11"
                                           x:Name="StatusTextBlock"
                                           Text="就绪"
                                           FontSize="12"
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </Grid>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- 底部状态栏 -->
            <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="10,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👤" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TotalUsersText" 
                               Text="" 
                               FontSize="12" 
                               Foreground="#666666"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>