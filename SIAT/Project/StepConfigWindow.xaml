<Window x:Class="SIAT.StepConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="步骤配置"
        Height="630"
        Width="700"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004175"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E1E4E8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#C9CDD0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C9CDD0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B6BBBF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E1E4E8" BorderThickness="0,0,0,1" Padding="15,10">
            <TextBlock Text="步骤配置" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- 步骤基本信息 -->
        <Border Grid.Row="1" Margin="15" Background="#F8F9FA" Padding="10" CornerRadius="4" BorderThickness="1" BorderBrush="#E1E4E8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="步骤名称: " Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Column="1" x:Name="StepNameText" Text="{Binding Step.Name}" FontWeight="SemiBold" Style="{StaticResource LabelStyle}" Margin="5,0,0,0"/>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 输入绑定设置 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="输入绑定设置" Style="{StaticResource SectionTitleStyle}"/>
                <Border BorderBrush="#E1E4E8" BorderThickness="1" CornerRadius="4" Margin="0,5,0,0">
                    <ListView x:Name="InputBindingsList" MinHeight="150" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="输入描述" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding InputDescription}" Padding="5,2" Width="190"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="输入绑定" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.ProjectVariables, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" 
                                                      SelectedItem="{Binding InputVariable}" 
                                                      DisplayMemberPath="VariableName" 
                                                      Width="250" 
                                                      Margin="5,2" 
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </StackPanel>

            <!-- 输出绑定设置 -->
            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="输出绑定设置" Style="{StaticResource SectionTitleStyle}"/>
                <Border BorderBrush="#E1E4E8" BorderThickness="1" CornerRadius="4" Margin="0,5,0,0">
                    <ListView x:Name="OutputBindingsList" MinHeight="150" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="输出描述" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding OutputDescription}" Padding="5,2" Width="190"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="输出绑定" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.ProjectVariables, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" 
                                                      SelectedItem="{Binding OutputVariable}" 
                                                      DisplayMemberPath="VariableName" 
                                                      Width="250" 
                                                      Margin="5,2" 
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </StackPanel>


        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,15,15,0">
            <Button x:Name="OKButton" Content="确定" Style="{StaticResource PrimaryButtonStyle}" Click="OKButton_Click" Width="80"/>
            <Button x:Name="CancelButton" Content="取消" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>