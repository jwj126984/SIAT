<Window x:Class="SIAT.ProjectEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="项目编辑" Height="800" Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004175"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#999999"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E1E4E8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#C9CDD0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C9CDD0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B6BBBF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标题样式 -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- 列表项样式 -->
        <Style x:Key="ListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                    <Setter Property="Foreground" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="83*"/>
            <ColumnDefinition Width="117*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E1E4E8" BorderThickness="0,0,0,1" Padding="15,10" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="项目编辑" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Text="项目名称: " VerticalAlignment="Center"/>
                <TextBlock x:Name="ProjectNameText" Text="{Binding ProjectConfig.Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <Button x:Name="SaveButton" Content="保存" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
                <Button x:Name="SaveAsButton" Content="另存为" Style="{StaticResource SecondaryButtonStyle}" Click="SaveAsButton_Click"/>
                <Button x:Name="CloseButton" Content="关闭" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="15,15,15,15" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：步骤添加列表 -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 设备选择 -->
                <TextBlock Grid.Row="0" Text="设备选择" Style="{StaticResource SectionTitleStyle}"/>
                <ListView Grid.Row="1" x:Name="DeviceList" ItemsSource="{Binding Devices}" Height="120" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="DeviceList_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="设备名称" Width="290" DisplayMemberBinding="{Binding Name}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 步骤列表 -->
                <TextBlock Grid.Row="2" Text="可用步骤" Style="{StaticResource SectionTitleStyle}"/>
                <Grid Grid.Row="2" Margin="0,25,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索框 -->
                    <Grid Grid.Row="0" Margin="0,0,0,5" Height="30">
                        <TextBox x:Name="StepSearchTextBox" Height="30" TextChanged="StepSearchTextBox_TextChanged" ToolTip="搜索步骤..." FontSize="13" Padding="5,2" Background="White" BorderThickness="1" BorderBrush="#CCCCCC"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="搜索步骤..." Foreground="#999999" FontSize="13" Margin="8,6,0,0" IsHitTestVisible="False" Visibility="Collapsed"/>
                    </Grid>
                    <ListView Grid.Row="1" x:Name="StepList" ItemsSource="{Binding FilteredSteps}" ItemContainerStyle="{StaticResource ListItemStyle}" MouseDoubleClick="StepList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="步骤名称" Width="290">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <!-- 中间：项目编辑列表 -->
            <Grid Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 项目标题 -->
                <TextBlock Grid.Row="0" Text="项目编辑列表" Style="{StaticResource SectionTitleStyle}"/>

                <!-- 用例列表 -->
                <ListView Grid.Row="1" x:Name="TestCaseList" ItemsSource="{Binding TestCaseSteps}" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="TestCaseList_SelectionChanged" MouseDoubleClick="TestCaseList_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="序号" Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Index}" Padding="5,2" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="步骤名称" Width="280">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Step.Name}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Step.Name}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="描述" Width="210">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Step.Description}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Step.Description}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 用例操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="MoveUpButton" Content="上移" Style="{StaticResource PrimaryButtonStyle}" Click="MoveUpButton_Click"/>
                    <Button x:Name="MoveDownButton" Content="下移" Style="{StaticResource PrimaryButtonStyle}" Click="MoveDownButton_Click"/>
                    <Button x:Name="DeleteStepButton" Content="删除" Style="{StaticResource PrimaryButtonStyle}" Click="DeleteStepButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- 右侧：变量列表管理 -->
            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 变量标题 -->
                <TextBlock Grid.Row="0" Text="变量管理" Style="{StaticResource SectionTitleStyle}"/>

                <!-- 变量列表 -->
                <ListView Grid.Row="1" x:Name="VariableList" ItemsSource="{Binding Variables}" ItemContainerStyle="{StaticResource ListItemStyle}" SelectionChanged="VariableList_SelectionChanged" MouseDoubleClick="VariableList_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="名称" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VariableName}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding VariableName}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="类型" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VariableType}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding VariableType}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="描述" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Description}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="单位" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Unit}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Unit}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="变量值" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" Padding="5,2" TextTrimming="CharacterEllipsis" ToolTip="{Binding Value}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Header="显示" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 变量操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="AddVariableButton" Content="添加变量" Style="{StaticResource PrimaryButtonStyle}" Click="AddVariableButton_Click"/>
                    <Button x:Name="EditVariableButton" Content="编辑" Style="{StaticResource SecondaryButtonStyle}" Click="EditVariableButton_Click"/>
                    <Button x:Name="DeleteVariableButton" Content="删除" Style="{StaticResource SecondaryButtonStyle}" Click="DeleteVariableButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E1E4E8" BorderThickness="0,1,0,0" Padding="15,8" Grid.ColumnSpan="2">
            <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="#666666"/>
        </Border>
    </Grid>
</Window>