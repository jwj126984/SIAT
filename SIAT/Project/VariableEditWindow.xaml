<Window x:Class="SIAT.VariableEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="变量编辑"
        Width="600"
        Height="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E1E4E8" BorderThickness="0,0,0,1" Padding="20,15">
            <TextBlock Text="变量编辑" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>
        
        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            
            <!-- 变量名称 -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="变量名称:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Variable.VariableName, Mode=TwoWay}" Margin="10,10,0,0" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF"/>
            
            <!-- 变量类型 -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="变量类型:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding VariableTypes}" SelectedItem="{Binding Variable.VariableType, Mode=TwoWay}" Margin="10,10,0,0" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF"/>
            
            <!-- 变量描述 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="描述:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Variable.Description, Mode=TwoWay}" Margin="10,10,0,0" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF"/>
            
            <!-- 单位 -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="单位:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Variable.Unit, Mode=TwoWay}" Margin="10,10,0,0" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF"/>
            
            <!-- 显示控制 -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="显示:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding Variable.IsVisible, Mode=TwoWay}" Margin="10,10,0,0" VerticalAlignment="Center"/>
            
            <!-- 变量值 -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="变量值:" VerticalAlignment="Center" Margin="0,10,0,0"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Variable.Value, Mode=TwoWay}" Margin="10,10,0,0" Height="30" Padding="8" BorderBrush="#D1D5DB" BorderThickness="1" Background="#FFFFFF"/>
            

            </Grid>
        </ScrollViewer>
        
        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,20,20">
            <Button Content="确定" Click="OKButton_Click" Width="80" Height="35" Margin="0,0,10,0" Background="#3498DB" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Click="CancelButton_Click" Width="80" Height="35" Background="#E1E4E8" Foreground="#2C3E50" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>