<Window x:Class="SIAT.AddEditDeviceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="设备设置"
        Width="600"
        Height="auto"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 设备名称 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <Label Content="设备名称:" Width="80" />
            <TextBox x:Name="DeviceNameTextBox" Width="200" />
        </StackPanel>

        <!-- 通讯方式 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <Label Content="通讯方式:" Width="80" />
            <ComboBox x:Name="CommunicationTypeComboBox" Width="200" SelectionChanged="CommunicationTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="Serial" Tag="Serial" />
                <ComboBoxItem Content="Network" Tag="Network" />
                <ComboBoxItem Content="CAN" Tag="CAN" />
                <ComboBoxItem Content="USB" Tag="USB" />
            </ComboBox>
        </StackPanel>

        <!-- 通讯参数 -->
        <GroupBox Grid.Row="4" Header="通讯参数" Margin="10">
            <Grid x:Name="ParamsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- 串口参数 -->
                <Grid x:Name="SerialParamsGrid" Visibility="Visible" Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="串口号:" Width="80" />
                        <ComboBox x:Name="SerialPortTextBox" Width="150" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="波特率:" Width="80" />
                        <ComboBox x:Name="BaudRateTextBox" Width="150" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="数据位:" Width="80" />
                        <TextBox x:Name="DataBitsTextBox" Width="150" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="校验位:" Width="80" />
                        <ComboBox x:Name="ParityComboBox" Width="150">
                            <ComboBoxItem Content="None" Tag="None" />
                            <ComboBoxItem Content="Odd" Tag="Odd" />
                            <ComboBoxItem Content="Even" Tag="Even" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="停止位:" Width="80" />
                        <TextBox x:Name="StopBitsTextBox" Width="150" />
                    </StackPanel>
                </Grid>

                <!-- 网络参数 -->
                <Grid x:Name="NetworkParamsGrid" Visibility="Collapsed" Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="IP地址:" Width="80" />
                        <TextBox x:Name="IPAddressTextBox" Width="150" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="端口:" Width="80" />
                        <TextBox x:Name="PortTextBox" Width="150" />
                    </StackPanel>
                </Grid>

                <!-- CAN参数 -->
                <Grid x:Name="CanParamsGrid" Visibility="Collapsed" Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- 设备类型配置 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="设备类型:" Width="100" />
                        <ComboBox x:Name="DeviceTypeComboBox" Width="150">
                            <ComboBoxItem Content="周立功 USBCAN-Ⅰ" Tag="ZLG_USBCAN_I" />
                            <ComboBoxItem Content="周立功 USBCAN-II" Tag="ZLG_USBCAN_II" />
                            <ComboBoxItem Content="周立功 USBCANFD-200U" Tag="ZLG_USBCANFD_200U" />
                            <ComboBoxItem Content="创芯科技 CANalyst-Ⅱ" Tag="CXKJ_CANALYST_II" />
                           
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- 基础配置 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="设备索引:" Width="100" />
                        <ComboBox x:Name="DeviceIndexComboBox" Width="150">
                            <ComboBoxItem Content="设备0" Tag="0" />
                            <ComboBoxItem Content="设备1" Tag="1" />
                            <ComboBoxItem Content="设备2" Tag="2" />
                            <ComboBoxItem Content="设备3" Tag="3" />
                            <ComboBoxItem Content="设备4" Tag="4" />
                            <ComboBoxItem Content="设备5" Tag="5" />
                            <ComboBoxItem Content="设备6" Tag="6" />
                            <ComboBoxItem Content="设备7" Tag="7" />
                            <ComboBoxItem Content="设备8" Tag="8" />
                            <ComboBoxItem Content="设备9" Tag="9" />
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="CAN通道:" Width="100" />
                        <ComboBox x:Name="CanChannelComboBox" Width="150">
                            <ComboBoxItem Content="CAN0" Tag="CAN0" />
                            <ComboBoxItem Content="CAN1" Tag="CAN1" />
                            <ComboBoxItem Content="CAN2" Tag="CAN2" />
                            <ComboBoxItem Content="CAN3" Tag="CAN3" />
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- CAN FD配置 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="CAN类型:" Width="100" />
                        <ComboBox x:Name="CanFdModeComboBox" Width="150" SelectionChanged="CanFdModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="CAN" Tag="false" />
                            <ComboBoxItem Content="CANFD" Tag="true" />
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="数据段波特率:" Width="100" />
                        <ComboBox x:Name="CanFdDataBaudRateComboBox" Width="150">
                            <ComboBoxItem Content="1 Mbps" Tag="1000000" />
                            <ComboBoxItem Content="2 Mbps" Tag="2000000" />
                            <ComboBoxItem Content="4 Mbps" Tag="4000000" />
                            <ComboBoxItem Content="5 Mbps" Tag="5000000" />
                            <ComboBoxItem Content="8 Mbps" Tag="8000000" />
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- 波特率配置 -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="仲裁波特率:" Width="100" />
                        <ComboBox x:Name="CanBaudRateComboBox" Width="150">
                            <ComboBoxItem Content="10 kbps" Tag="10000" />
                            <ComboBoxItem Content="20 kbps" Tag="20000" />
                            <ComboBoxItem Content="50 kbps" Tag="50000" />
                            <ComboBoxItem Content="100 kbps" Tag="100000" />
                            <ComboBoxItem Content="125 kbps" Tag="125000" />
                            <ComboBoxItem Content="250 kbps" Tag="250000" />
                            <ComboBoxItem Content="500 kbps" Tag="500000" />
                            <ComboBoxItem Content="800 kbps" Tag="800000" />
                            <ComboBoxItem Content="1 Mbps" Tag="1000000" />
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="工作模式:" Width="100" />
                        <ComboBox x:Name="CanWorkModeComboBox" Width="150">
                            <ComboBoxItem Content="正常模式" Tag="Normal" />
                            <ComboBoxItem Content="只听模式" Tag="ListenOnly" />
                            <ComboBoxItem Content="自测试模式" Tag="SelfTest" />
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- 采样点配置 -->
                    <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="仲裁采样点(%):" Width="100" />
                        <TextBox x:Name="ArbitrationSamplePointTextBox" Width="150" Text="80" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="数据采样点(%):" Width="100" />
                        <TextBox x:Name="DataSamplePointTextBox" Width="150" Text="80" />
                    </StackPanel>
                    
                    <!-- 滤波配置 -->
                    <StackPanel Grid.Row="9" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="滤波模式:" Width="100" />
                        <ComboBox x:Name="CanFilterModeComboBox" Width="150">
                            <ComboBoxItem Content="双滤波" Tag="DualFilter" />
                            <ComboBoxItem Content="单滤波" Tag="SingleFilter" />
                        </ComboBox>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="10" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="验收码:" Width="100" />
                        <TextBox x:Name="AcceptanceCodeTextBox" Width="150" Text="0x00000000" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="11" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="验收屏蔽码:" Width="100" />
                        <TextBox x:Name="AcceptanceMaskTextBox" Width="150" Text="0xFFFFFFFF" />
                    </StackPanel>
                    
                    <!-- 硬件配置 -->
                    <StackPanel Grid.Row="12" Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="终端电阻:" Width="100" />
                        <CheckBox x:Name="IsTerminalResistorCheckBox" />
                        <Label Content="错误帧处理:" Width="80" Margin="20,0,0,0" />
                        <CheckBox x:Name="EnableErrorFrameCheckBox" />
                    </StackPanel>
                </Grid>

                <!-- USB参数 -->
                <Grid x:Name="UsbParamsGrid" Visibility="Collapsed" Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                        <Label Content="USB设备ID:" Width="80" />
                        <ComboBox x:Name="UsbDeviceIdTextBox" Width="150" />
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="10" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="保存" Width="80" Margin="0,0,10,0" Click="SaveButton_Click" />
            <Button x:Name="CancelButton" Content="取消" Width="80" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>