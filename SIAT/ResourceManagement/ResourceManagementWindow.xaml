<Window x:Class="SIAT.ResourceManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="资源管理"
        Width="auto"
        Height="700"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 小按钮样式 -->
        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <LinearGradientBrush x:Key="HeaderBackgroundGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0078D4" Offset="0"/>
            <GradientStop Color="#005A9E" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FooterBackgroundGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0078D4" Offset="0"/>
            <GradientStop Color="#005A9E" Offset="1"/>
        </LinearGradientBrush>

        <!-- ListView样式 -->
        <Style x:Key="ListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListView">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5" 
                                Background="{TemplateBinding Background}">
                            <ScrollViewer Padding="{TemplateBinding Padding}">
                                <StackPanel>
                                    <GridViewHeaderRowPresenter Columns="{Binding View.Columns, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <ItemsPresenter/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem样式 -->
        <Style x:Key="ListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E6F2FF"/>
                    <Setter Property="Foreground" Value="#0078D4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- GridView列头样式 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GroupBox样式 -->
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Background="White" 
                                Padding="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{TemplateBinding Header}" 
                                           Margin="10,0,0,0" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Foreground="#0078D4"/>
                                <ContentPresenter Grid.Row="1" 
                                                  Margin="5"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F8F9FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 设备列表区域 -->
        <GroupBox Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Header="设备列表" Style="{StaticResource GroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ListView x:Name="DeviceListView" Grid.Row="0" Margin="5" SelectionChanged="DeviceListView_SelectionChanged"
                          MouseDoubleClick="DeviceListView_MouseDoubleClick" MouseLeftButtonUp="DeviceListView_MouseLeftButtonUp"
                          Style="{StaticResource ListViewStyle}">
                    <ListView.ItemContainerStyle>
                        <StaticResource ResourceKey="ListViewItemStyle"/>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                                            <GridViewColumn Width="30" Header="">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="150" Header="设备名称" DisplayMemberBinding="{Binding Name}" />
                                            <GridViewColumn Width="120" Header="通讯方式" DisplayMemberBinding="{Binding CommunicationType}" />
                                            <GridViewColumn Width="80" Header="状态" DisplayMemberBinding="{Binding Status}" />
                                        </GridView>
                    </ListView.View>
                </ListView>
                <Grid Grid.Row="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AddDeviceButton" Content="新增设备" Margin="0,0,5,0" Click="AddDeviceButton_Click" 
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="0" />
                    <Button x:Name="EditDeviceButton" Content="修改设备" Margin="0,0,5,0" Click="EditDeviceButton_Click" IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="1" />
                    <Button x:Name="DeleteDeviceButton" Content="删除设备" Click="DeleteDeviceButton_Click" IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="2" />
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 步骤列表区域 -->
        <GroupBox Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Header="步骤列表" Style="{StaticResource GroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ListView x:Name="StepListView" Grid.Row="0" Margin="5" SelectionChanged="StepListView_SelectionChanged" MouseDoubleClick="StepListView_MouseDoubleClick" MouseLeftButtonUp="StepListView_MouseLeftButtonUp"
                          Style="{StaticResource ListViewStyle}">
                    <ListView.ItemContainerStyle>
                        <StaticResource ResourceKey="ListViewItemStyle"/>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                                            <GridViewColumn Width="30" Header="">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="120" Header="步骤名称" DisplayMemberBinding="{Binding Name}" />
                                            <GridViewColumn Width="120" Header="协议类型" DisplayMemberBinding="{Binding Protocol.Type}" />
                                            <GridViewColumn Width="200" Header="协议内容">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Protocol.Content}" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        </GridView>
                    </ListView.View>
                </ListView>
                <Grid Grid.Row="1" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AddStepButton" Content="新增步骤" Margin="0,0,5,0" Click="AddStepButton_Click" IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="0" />
                    <Button x:Name="EditStepButton" Content="修改步骤" Margin="0,0,5,0" Click="EditStepButton_Click" IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="1" />
                    <Button x:Name="DeleteStepButton" Content="删除步骤" Click="DeleteStepButton_Click" IsEnabled="False"
                            Style="{StaticResource PrimaryButtonStyle}" Grid.Column="2" />
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 详细信息显示区域 -->
        <GroupBox Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Header="详细信息" Style="{StaticResource GroupBoxStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="选择设备或步骤查看详细信息" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" FontWeight="Bold" />
                
                <ScrollViewer Grid.Row="1" Margin="5">
                    <StackPanel x:Name="DetailStackPanel" Orientation="Vertical" 
                                DataContext="{Binding ElementName=DeviceListView, Path=SelectedItem}">
                        <!-- 设备详细信息 -->
                        <StackPanel x:Name="DeviceDetailPanel" Visibility="Collapsed" Margin="5">
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                <TextBlock Text="设备信息" FontWeight="Bold" FontSize="16" 
                                           Foreground="#0078D4" Padding="0,0,0,5"/>
                            </Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="设备名称:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="5" />
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="通讯方式:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CommunicationType}" Margin="5" />
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="状态:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" Margin="5" />
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="是否启用:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding IsEnabled}" Margin="5" />
                            </Grid>
                            
                            <!-- 通讯参数根据通讯方式动态显示 -->
                            <StackPanel Orientation="Vertical" Margin="5,10,5,0">
                                <!-- 串口参数 -->
                                <StackPanel x:Name="SerialParamsPanel" Orientation="Vertical">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CommunicationType}" Value="Serial">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                            <TextBlock Text="串口参数" FontWeight="Bold" FontSize="14" 
                                                       Foreground="#0078D4" Padding="0,0,0,5"/>
                                        </Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="串口号:" Margin="5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Params.SerialPort}" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率:" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Params.BaudRate}" Margin="5" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="数据位:" Margin="5" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Params.DataBits}" Margin="5" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="校验位:" Margin="5" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Params.Parity}" Margin="5" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="停止位:" Margin="5" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Params.StopBits}" Margin="5" />
                                    </Grid>
                                </StackPanel>
                                
                                <!-- 网络参数 -->
                                <StackPanel x:Name="NetworkParamsPanel" Orientation="Vertical">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CommunicationType}" Value="Network">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                            <TextBlock Text="网络参数" FontWeight="Bold" FontSize="14" 
                                                       Foreground="#0078D4" Padding="0,0,0,5"/>
                                        </Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址:" Margin="5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Params.IPAddress}" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Params.Port}" Margin="5" />
                                    </Grid>
                                </StackPanel>
                                
                                <!-- CAN参数 -->
                                <StackPanel x:Name="CanParamsPanel" Orientation="Vertical">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CommunicationType}" Value="CAN">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                            <TextBlock Text="CAN参数" FontWeight="Bold" FontSize="14" 
                                                       Foreground="#0078D4" Padding="0,0,0,5"/>
                                        </Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="CAN通道:" Margin="5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Params.CanChannel}" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率:" Margin="5" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Params.CanBaudRate}" Margin="5" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CAN FD:" Margin="5" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Params.IsCanFd}" Margin="5" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="终端电阻:" Margin="5" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Params.IsTerminalResistorEnabled}" Margin="5" />
                                    </Grid>
                                </StackPanel>
                                
                                <!-- USB参数 -->
                                <StackPanel x:Name="UsbParamsPanel" Orientation="Vertical">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CommunicationType}" Value="USB">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                            <TextBlock Text="USB参数" FontWeight="Bold" FontSize="14" 
                                                       Foreground="#0078D4" Padding="0,0,0,5"/>
                                        </Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="设备ID:" Margin="5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Params.UsbDeviceId}" Margin="5" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                            
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,15,0,10">
                                <TextBlock Text="步骤列表" FontWeight="Bold" FontSize="14" 
                                           Foreground="#0078D4" Padding="0,0,0,5"/>
                            </Border>
                            <ListView ItemsSource="{Binding Steps}" Margin="10,0,0,0" MaxHeight="200"
                                      Style="{StaticResource ListViewStyle}">
                                <ListView.ItemContainerStyle>
                                    <StaticResource ResourceKey="ListViewItemStyle"/>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="30" Header="">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Width="150" Header="步骤名称" DisplayMemberBinding="{Binding Name}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                        
                        <!-- 步骤详细信息 -->
                        <StackPanel x:Name="StepDetailPanel" Visibility="Collapsed" Margin="5">
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,0,0,10">
                                <TextBlock Text="步骤信息" FontWeight="Bold" FontSize="16" 
                                           Foreground="#0078D4" Padding="0,0,0,5"/>
                            </Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="步骤名称:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="5" />
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="协议类型:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Protocol.Type}" Margin="5" />
                                
                                <!-- CAN FD和CAN ID只在CAN协议下显示 -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="CAN FD:" FontWeight="Bold" Margin="5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Protocol.Type}" Value="CAN">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Protocol.IsCanFd}" Margin="5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Protocol.Type}" Value="CAN">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="CAN ID:" FontWeight="Bold" Margin="5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Protocol.Type}" Value="CAN">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Protocol.Id}" Margin="5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Protocol.Type}" Value="CAN">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="协议内容:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Protocol.Content}" Margin="5" TextWrapping="Wrap" />
                                
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="是否启用:" FontWeight="Bold" Margin="5" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding IsEnabled}" Margin="5" />
                            </Grid>
                            
                            <Border BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Margin="0,15,0,10">
                                <TextBlock Text="变量信息" FontWeight="Bold" FontSize="16" 
                                           Foreground="#0078D4" Padding="0,0,0,5"/>
                            </Border>
                            <ListView x:Name="ResultVariablesListView" ItemsSource="{Binding ResultVariables}" Margin="5" MaxHeight="300"
                                      Style="{StaticResource ListViewStyle}">
                                <ListView.ItemContainerStyle>
                                    <StaticResource ResourceKey="ListViewItemStyle"/>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="30" Header="">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="True" IsEnabled="False" HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Width="120" Header="变量名称" DisplayMemberBinding="{Binding Name}" />
                                        <GridViewColumn Width="60" Header="单位" DisplayMemberBinding="{Binding Unit}" />
                                        <GridViewColumn Width="80" Header="起始位" DisplayMemberBinding="{Binding StartBit}" />
                                        <GridViewColumn Width="80" Header="结束位" DisplayMemberBinding="{Binding EndBit}" />
                                        <GridViewColumn Width="60" Header="长度" DisplayMemberBinding="{Binding Length}" />
                                        <GridViewColumn Width="80" Header="分辨率" DisplayMemberBinding="{Binding Resolution}" />
                                        <GridViewColumn Width="80" Header="偏移量" DisplayMemberBinding="{Binding Offset}" />
                                        <GridViewColumn Width="80" Header="字节序" DisplayMemberBinding="{Binding Endian}" />
                                        <GridViewColumn Width="100" Header="CAN ID" DisplayMemberBinding="{Binding CanId}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </GroupBox>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Orientation="Horizontal" Margin="5" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="保存" Margin="0,0,5,0" Click="SaveButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}" />
            <Button x:Name="CloseButton" Content="关闭" Click="CloseButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>