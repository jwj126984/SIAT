<Window x:Class="SIAT.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        mc:Ignorable="d"
        Title="SIAT - 用户登录" 
        Height="430" 
        Width="700"
        MinHeight="380"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- 文本框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 密码框样式 -->
        <Style TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 切换按钮样式 -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Width" Value="75"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#005A9E"/>
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 关闭按钮样式 -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 复选框样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <!-- 文本块样式 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 标签样式 -->
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <!-- 主窗口阴影效果 -->
    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid Background="White">
            <!-- 背景装饰 - 左侧蓝色区域 -->
            <Rectangle Fill="#0078D4" HorizontalAlignment="Left" Width="280">
                <Rectangle.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.OpacityMask>
            </Rectangle>

            <!-- 主要内容区域 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧装饰区域 -->
                <Grid Grid.Column="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Width="250" Margin="20">
                        <TextBlock Text="远聪" 
                                   FontSize="36" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   Margin="0,0,0,15"
                                   TextAlignment="Center"/>
                        <TextBlock Text="自动测试系统" 
                                   FontSize="20" 
                                   Foreground="White" 
                                   Opacity="0.9"
                                   TextAlignment="Center"/>
                        <TextBlock Text="欢迎回来，请登录您的账户" 
                                   FontSize="16" 
                                   Foreground="White" 
                                   Opacity="0.8" 
                                   Margin="0,20,0,0"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- 分隔线 -->
                <Rectangle Grid.Column="1" Width="1" Fill="#CCCCCC" Margin="0,30" VerticalAlignment="Stretch"/>

                <!-- 右侧登录表单区域 -->
                <Grid Grid.Column="2" Margin="30,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 窗口控制按钮（右上角） -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,15">
                            <!-- 最小化按钮 -->
                            <Button x:Name="MinimizeButton"
                                    Content="−" 
                                    Style="{StaticResource CloseButtonStyle}"
                                    Click="MinimizeButton_Click"
                                    Margin="0,0,5,0"/>
                            <!-- 最大化按钮 -->
                            <Button x:Name="MaximizeButton"
                                    Content="□" 
                                    Style="{StaticResource CloseButtonStyle}"
                                    Click="MaximizeButton_Click"
                                    Margin="0,0,5,0"/>
                            <!-- 关闭按钮 -->
                            <Button x:Name="CloseButton"
                                    Content="✕" 
                                    Style="{StaticResource CloseButtonStyle}"
                                    Click="CloseButton_Click"/>
                        </StackPanel>

                        <!-- 登录标题 -->
                        <TextBlock Grid.Row="1"
                                   Text="用户登录" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="#333333" 
                                   Margin="0,0,0,25" 
                                   HorizontalAlignment="Center"/>

                        <!-- 用户名输入 -->
                        <Label Grid.Row="2"
                               Content="用户名" 
                               Foreground="#333333"/>
                        <TextBox Grid.Row="3"
                                 x:Name="UsernameTextBox" 
                                 Margin="0,0,0,10"
                                 TextChanged="UsernameTextBox_TextChanged"
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"/>

                        <!-- 密码输入区域 -->
                        <Label Grid.Row="4"
                               Content="密码" 
                               Foreground="#333333"/>

                        <!-- 密码框容器 -->
                        <Grid Grid.Row="5" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 密码框（默认显示） -->
                            <PasswordBox x:Name="PasswordBox" 
                                         Grid.Column="0"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PasswordBox_GotFocus"
                                         LostFocus="PasswordBox_LostFocus"/>

                            <!-- 显示密码的文本框（默认隐藏） -->
                            <TextBox x:Name="PasswordTextBox" 
                                     Grid.Column="0"
                                     Visibility="Collapsed"
                                     TextChanged="PasswordTextBox_TextChanged"
                                     GotFocus="TextBox_GotFocus"
                                     LostFocus="TextBox_LostFocus"/>

                            <!-- 显示密码按钮 -->
                            <Button x:Name="ShowPasswordButton" 
                                    Grid.Column="1" 
                                    Content="显示密码" 
                                    Style="{StaticResource ToggleButtonStyle}"
                                    Margin="5,5,0,5"
                                    Click="ShowPasswordButton_Click"/>
                        </Grid>

                        <!-- 记住密码选项 -->
                        <StackPanel Grid.Row="6" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,15">
                            <CheckBox x:Name="RememberPasswordCheckBox"
                                      Content="记住密码"
                                      IsChecked="False"
                                      Checked="RememberPasswordCheckBox_Checked"
                                      Unchecked="RememberPasswordCheckBox_Unchecked"/>
                        </StackPanel>

                        <!-- 登录按钮 -->
                        <Button Grid.Row="7"
                                x:Name="LoginButton" 
                                Content="登 录" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,0,15"
                                Click="LoginButton_Click"/>

                        <!-- 底部提示信息区域（固定高度） -->
                        <Border Grid.Row="8"
                                Height="40"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="MessageTextBlock" 
                                       Text="" 
                                       Foreground="#FF0000" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>