<Window x:Class="SIAT.TestInterfaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIAT"
        xmlns:tset="clr-namespace:SIAT.TSET"
        mc:Ignorable="d"
        Title="测试界面" 
        Height="720" 
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- 转换器声明 -->
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <local:IndexConverter x:Key="IndexConverter"/>
        <local:StatusToTextConverter x:Key="StatusToTextConverter"/>
        <local:TestStepStatusToColorConverter x:Key="TestStepStatusToColorConverter"/>
        <tset:ExpandedToSymbolConverter x:Key="ExpandedToSymbolConverter"/>

        <!-- 窗口控制按钮样式 -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 关闭按钮特殊样式 -->
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 主要按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="BorderBrush" Value="#218838"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="BorderBrush" Value="#C82333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C82333"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BD2130"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 小按钮样式 -->
        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <!-- 数据网格样式 -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="32"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F5F5F5"/>
            <Setter Property="VerticalGridLinesBrush" Value="#F5F5F5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- 文本框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- 组合框样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- 状态指示灯样式 -->
        <Style x:Key="StatusIndicatorStyle" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- 统计卡片样式 -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <!-- 窗口阴影效果 -->
    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.2" Direction="270"/>
        </Border.Effect>

        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 控制区域 -->
                <RowDefinition Height="*"/>
                <!-- 主要内容 -->
                <RowDefinition Height="Auto"/>
                <!-- 测试进度条 -->
                <RowDefinition Height="Auto"/>
                <!-- 状态栏 -->
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="#0078D4" 
                    BorderBrush="#005A9E" BorderThickness="0,0,0,1" CornerRadius="4,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标和标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="🧪" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="测试界面" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 测试状态指示 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border x:Name="TestStatusIndicator" 
                                Width="8" 
                                Height="8" 
                                CornerRadius="4"
                                Background="#6C757D"
                                Margin="0,0,6,0"/>
                        <TextBlock x:Name="TestStatusText" 
                                   Text="就绪" 
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12.5"/>
                    </StackPanel>

                    <!-- 窗口控制按钮组 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <!-- 缩小按钮 -->
                        <Button x:Name="WindowMinimizeButton"
                                Content="🗕" 
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="WindowMinimizeButton_Click"/>
                        <!-- 全屏按钮 -->
                        <Button x:Name="WindowMaximizeButton"
                                Content="🗗" 
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="WindowMaximizeButton_Click"/>
                        <!-- 关闭按钮 -->
                        <Button x:Name="WindowCloseButton"
                                Content="🗙" 
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Click="WindowCloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 控制区域 -->
            <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 文件选择区域 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📁" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="用例选择:" FontWeight="Medium" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <Border Background="White" BorderBrush="#D1D1D1" BorderThickness="1" CornerRadius="3" Width="200" Height="30" Margin="0,0,8,0">
                            <TextBlock x:Name="TestCaseFileText" 
                                       Text="未选择用例文件" 
                                       FontSize="12" 
                                       Foreground="#666666"
                                       VerticalAlignment="Center"
                                       Margin="8,0"/>
                        </Border>
                        <Button x:Name="SelectTestCaseButton"
                                Content="选择文件" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="80"
                                Margin="0,0,0,0"
                                Click="SelectTestCaseButton_Click"/>
                    </StackPanel>

                    <!-- 当前用例信息 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="CurrentTestCaseText" 
                                   Text="" 
                                   FontSize="12" 
                                   Foreground="#333333"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TestCaseProjectsText" 
                                   Text="" 
                                   FontSize="11" 
                                   Foreground="#666666"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- 按钮组 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="测试设置" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="90"
                                Click="TestSettingsButton_Click"/>

                        <Button x:Name="StartTestButton"
                                Content="▶ 启动测试" 
                                Style="{StaticResource SuccessButtonStyle}"
                                Width="90"
                                Click="StartTestButton_Click" Cursor=""/>

                        <Button x:Name="StopTestButton"
                                Content="⏹ 停止测试" 
                                Style="{StaticResource DangerButtonStyle}"
                                Width="90"
                                IsEnabled="False"
                                Click="StopTestButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主要内容区域 -->
            <Grid Grid.Row="2" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="400"/>
                    <ColumnDefinition Width="1*" MinWidth="340"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：测试步骤列表 -->
                <Border Grid.Column="0" Margin="12,12,6,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📋" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="测试列表" 
                                   FontSize="13.5" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        </StackPanel>

                        <!-- 测试步骤树形视图 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38*"/>
                                <ColumnDefinition Width="43*"/>
                                <ColumnDefinition Width="659*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 列头 -->
                            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,2" Grid.ColumnSpan="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" MinWidth="180"/>
                                        <ColumnDefinition Width="2*" MinWidth="140"/>
                                        <ColumnDefinition Width="2*" MinWidth="140"/>
                                        <ColumnDefinition Width="1*" MinWidth="80"/>
                                        <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                        <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="变量名称" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="合格值" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="实测值" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="单位" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="测试结果" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="耗时" FontSize="12" FontWeight="Bold" Foreground="#222222" Padding="8,6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TreeView 
                                      x:Name="TestStepsTreeView" 
                                      ItemsSource="{Binding TestProjects}"
                                      BorderThickness="0"
                                      Background="White" Grid.ColumnSpan="3" Margin="0,29,0,0" Grid.RowSpan="2">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="{x:Type TreeViewItem}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                                                    <StackPanel>
                                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                                        <ItemsPresenter/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E9ECEF"/>
                                                <Setter Property="Foreground" Value="#333333"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Variables}">
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="8,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="3*" MinWidth="180"/>
                                                            <ColumnDefinition Width="2*" MinWidth="140"/>
                                                            <ColumnDefinition Width="2*" MinWidth="140"/>
                                                            <ColumnDefinition Width="1*" MinWidth="80"/>
                                                            <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                                            <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 变量名称列 -->
                                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Medium" Foreground="#333333"/>

                                                        <!-- 合格值列 -->
                                                        <TextBlock Grid.Column="1" Text="{Binding QualifiedValue}" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>

                                                        <!-- 实测值列 -->
                                                        <TextBlock Grid.Column="2" Text="{Binding ActualValue}" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Medium" Foreground="#333333"/>

                                                        <!-- 单位列 -->
                                                        <TextBlock Grid.Column="3" Text="{Binding Unit, FallbackValue='-'}" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>

                                                        <!-- 状态列 -->
                                                        <TextBlock Grid.Column="4" Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Status, Converter={StaticResource TestStepStatusToColorConverter}}"/>

                                                        <!-- 耗时列 -->
                                                        <TextBlock Grid.Column="5" Text="{Binding Duration, StringFormat='{}{0:F3}s'}" FontSize="11.5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>

                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>

                                        <Border Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,2" Padding="8,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*" MinWidth="180"/>
                                                    <ColumnDefinition Width="2*" MinWidth="140"/>
                                                    <ColumnDefinition Width="2*" MinWidth="140"/>
                                                    <ColumnDefinition Width="1*" MinWidth="80"/>
                                                    <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                                    <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- 项目名称列 -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Border Width="10" 
                                                        Height="10" 
                                                        CornerRadius="5" 
                                                        Margin="0,0,8,0"
                                                        Background="{Binding OverallStatus, Converter={StaticResource TestStepStatusToColorConverter}}"/>
                                                    <TextBlock Text="{Binding Name}" 
                                                           FontSize="12.5" 
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" 
                                                           Foreground="#222222"/>
                                                </StackPanel>

                                                <!-- 项目耗时显示 -->
                                                <TextBlock Grid.Column="5" 
                                                       Text="{Binding TotalDurationSeconds, StringFormat={}{0:F3}s}" 
                                                       FontSize="11.5" 
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" 
                                                       Foreground="#555555" 
                                                       FontWeight="Medium"/>
                                            </Grid>
                                        </Border>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 右侧：信息面板 -->
                <Border Grid.Column="1" Margin="6,12,12,12" BorderBrush="#E0E0E0" BorderThickness="1" 
                        Background="#F9FAFB" CornerRadius="4">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 条码扫描区域 -->
                        <Border Grid.Row="0" Style="{StaticResource StatCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="📷" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="条码扫描" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="BarcodeText" 
                                                   Text="" 
                                                   FontSize="13" 
                                                   FontWeight="Medium"
                                                   Foreground="#666666"
                                                   VerticalAlignment="Center"
                                                   AcceptsReturn="False"
                                                   TextAlignment="Left"
                                                   ToolTip="请扫描或输入产品条码"
                                                   TextChanged="BarcodeText_TextChanged"/>

                                        <Button Grid.Column="1" 
                                                Content="模拟扫描" 
                                                Style="{StaticResource SmallButtonStyle}"
                                                Width="70"
                                                Click="SimulateScanButton_Click"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="产品:" FontWeight="Medium" Margin="0,0,4,0" Foreground="#555555" FontSize="12"/>
                                    <TextBlock x:Name="ProductNameText" Text="未识别" Foreground="#333333" FontSize="12"/>
                                    <TextBlock Text=" | 批次:" FontWeight="Medium" Margin="8,0,4,0" Foreground="#555555" FontSize="12"/>
                                    <TextBlock x:Name="BatchNumberText" Text="N/A" Foreground="#333333" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 统计信息区域 -->
                        <Border Grid.Row="1" Style="{StaticResource StatCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 累计统计 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="📊" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="累计统计" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button x:Name="ModifyStatsButton" 
                                                Content="修改" 
                                                Style="{StaticResource SmallButtonStyle}"
                                                Width="50"
                                                Click="ModifyStatsButton_Click"/>
                                    </StackPanel>

                                    <!-- 统计数值行 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 第一行：总测试数 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="总测试数:" FontWeight="Medium" Width="70" VerticalAlignment="Center" Foreground="#555555" FontSize="12"/>
                                            <Border x:Name="TotalTestsBorder" 
                                                    Background="White" 
                                                    BorderBrush="#D1D1D1" 
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Width="60"
                                                    Height="26"
                                                    Margin="4,0,0,0">
                                                <TextBlock x:Name="TotalTestsText" 
                                                           Text="0" 
                                                           FontSize="12"
                                                           Foreground="#0078D4"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBox x:Name="TotalTestsEditBox" 
                                                    Text="0" 
                                                    Width="60" 
                                                    Height="26"
                                                    FontSize="12"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,0,0"
                                                    Visibility="Collapsed"/>
                                        </StackPanel>

                                        <!-- 第二行：总通过数 -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="总通过数:" FontWeight="Medium" Width="70" VerticalAlignment="Center" Foreground="#555555" FontSize="12"/>
                                            <Border x:Name="TotalPassedBorder" 
                                                    Background="White" 
                                                    BorderBrush="#D1D1D1" 
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Width="60"
                                                    Height="26"
                                                    Margin="4,0,0,0">
                                                <TextBlock x:Name="TotalPassedText" 
                                                           Text="0" 
                                                           FontSize="12"
                                                           Foreground="#28A745"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBox x:Name="TotalPassedEditBox" 
                                                    Text="0" 
                                                    Width="60" 
                                                    Height="26"
                                                    FontSize="12"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,0,0"
                                                    Visibility="Collapsed"/>
                                        </StackPanel>

                                        <!-- 第三行：总失败数 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="总失败数:" FontWeight="Medium" Width="70" VerticalAlignment="Center" Foreground="#555555" FontSize="12"/>
                                            <Border x:Name="TotalFailedBorder" 
                                                    Background="White" 
                                                    BorderBrush="#D1D1D1" 
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Width="60"
                                                    Height="26"
                                                    Margin="4,0,0,0">
                                                <TextBlock x:Name="TotalFailedText" 
                                                           Text="0" 
                                                           FontSize="12"
                                                           Foreground="#DC3545"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBox x:Name="TotalFailedEditBox" 
                                                    Text="0" 
                                                    Width="60" 
                                                    Height="26"
                                                    FontSize="12"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,0,0"
                                                    Visibility="Collapsed"/>
                                        </StackPanel>

                                        <!-- 第四行：通过率 -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="通过率:" FontWeight="Medium" Width="70" VerticalAlignment="Center" Foreground="#555555" FontSize="12"/>
                                            <Border Background="White" 
                                                    BorderBrush="#D1D1D1" 
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Width="60"
                                                    Height="26"
                                                    Margin="4,0,0,0">
                                                <TextBlock x:Name="PassRateText" 
                                                           Text="0.00%" 
                                                           FontSize="12"
                                                           Foreground="#17A2B8"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- 时间统计 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <TextBlock Text="⏱️" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="时间统计" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="本次耗时:" FontWeight="Medium" Width="70" Foreground="#555555" FontSize="12"/>
                                        <TextBlock x:Name="CurrentTestTimeText" Text="0.000s" FontSize="12" Foreground="#6C757D"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 信息日志 -->
                        <StackPanel Grid.Row="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="📝" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="信息日志" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Height="180">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                                    <TextBlock x:Name="LogTextBlock" 
                                               TextWrapping="Wrap" 
                                               FontFamily="Consolas, 'Cascadia Code', 'Courier New'" 
                                               FontSize="10.5"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 测试进度条 -->
            <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 进度图标 -->
                    <TextBlock Grid.Column="0" Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    
                    <!-- 进度条 -->
                    <Border Grid.Column="1" Background="#E9ECEF" BorderBrush="#D1D1D1" BorderThickness="1" CornerRadius="6" Height="24" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" Color="#CCCCCC" BlurRadius="3" Opacity="0.6"/>
                        </Border.Effect>
                        <Border x:Name="ProgressBarFill" 
                                CornerRadius="5" 
                                HorizontalAlignment="Left" 
                                Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0078D4" Offset="0.0"/>
                                    <GradientStop Color="#1E90FF" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    
                    <!-- 进度百分比 -->
                    <TextBlock Grid.Column="2" x:Name="ProgressPercentageText" 
                               Text="0%" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#2D2D2D" 
                               VerticalAlignment="Center" 
                               Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- 底部状态栏 -->
            <Border Grid.Row="4" Background="#F8F9FA" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" CornerRadius="0,0,4,4" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 状态信息 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔵" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="状态:" FontWeight="Medium" Margin="0,0,4,0" Foreground="#555555" FontSize="11.5"/>
                        <TextBlock x:Name="StatusMessageText" Text="系统就绪" Foreground="#333333" FontSize="11.5"/>
                        <TextBlock Text=" | 👤" FontSize="11" Margin="8,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="当前用户:" FontWeight="Medium" Margin="0,0,4,0" Foreground="#555555" FontSize="11.5"/>
                        <TextBlock x:Name="CurrentUserText" Text="未登录" Foreground="#333333" FontSize="11.5"/>
                    </StackPanel>

                    <!-- 版本和时间 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentTimeText" Text="00:00:00" FontSize="11.5" Foreground="#666666" Margin="0,0,10,0"/>
                        <TextBlock Text="v1.0.0" FontSize="11.5" Foreground="#888888"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>