{
  "Logging": {
    "LogLevel": "Information",
    "LogFilePath": "Logs/siat-",
    "MaxLogFileSizeMB": 10,
    "RetainedFileCountLimit": 30,
    "EnableConsoleLogging": true,
    "EnableFileLogging": true
  },
  "Communication": {
    "ConnectionPoolSize": 10,
    "ConnectionTimeoutMinutes": 30,
    "DefaultBaudRate": 9600,
    "DefaultSerialPort": "COM1",
    "DefaultIpAddress": "192.168.1.1",
    "DefaultPort": 8080,
    "DefaultCanBaudRate": 500000,
    "DeviceConfigurations": {}
  },
  "Test": {
    "DefaultTimeoutSeconds": 30,
    "MaxRetryCount": 3,
    "EnableAutoSave": true,
    "AutoSaveIntervalMinutes": 5,
    "DefaultTestCasePath": "TestCases",
    "DefaultProjectPath": "Projects",
    "DefaultDevicePath": "Devices"
  },
  "UI": {
    "Theme": "Light",
    "Language": "zh-CN",
    "EnableAnimations": true,
    "AnimationDurationMs": 300,
    "ShowToolTips": true,
    "ConfirmOnExit": true,
    "MainWindow": {
      "Width": 1200.0,
      "Height": 800.0,
      "Left": 100.0,
      "Top": 100.0,
      "IsMaximized": false
    }
  }
}